<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VERA v1.4 – Deal Closer (démo)</title>
<style>
:root{
  --bg:#07070e; --panel:#0d0f1a; --panel2:#111827;
  --text:#f1f5f9; --muted:#94a3b8; --dim:#64748b;
  --green:#34d399; --blue:#60a5fa; --gold:#fbbf24;
  --red:#f87171; --purple:#a78bfa;
  --border:rgba(255,255,255,0.08);
}
*{box-sizing:border-box;font-family:system-ui,Arial;}
body{ margin:0; background:var(--bg); color:var(--text); }
header{
  padding:12px 14px; display:flex;
  justify-content:space-between; align-items:center;
  border-bottom:1px solid var(--border);
  background:rgba(10,10,20,0.8); backdrop-filter:blur(10px);
}
h1{ font-size:14px; margin:0; }
.badge{
  font-size:10px; padding:3px 8px;
  border:1px solid var(--border); border-radius:6px;
  color:var(--muted); background:#1a1c2a;
}
.container{ padding:12px; max-width:800px; margin:auto; }
.pipeline{ display:flex; flex-direction:column; gap:8px; margin-bottom:12px; }
.step{
  display:flex; justify-content:space-between; padding:10px;
  background:var(--panel); border:1px solid var(--border); border-radius:10px;
}
.left{ display:flex; align-items:center; gap:8px; }
.dot{ width:8px; height:8px; border-radius:50%; }
.label{ font-size:12px; }
.state{ font-size:11px; color:var(--muted); }
.kpis{ display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:8px; margin-bottom:12px; }
.kpi{ background:var(--panel); border:1px solid var(--border); border-radius:10px; padding:10px; }
.kpi .v{ font-size:20px; font-weight:700; }
.kpi .t{ font-size:10px; color:var(--muted); text-transform:uppercase; }
.kpi .small{ font-size:9px; color:var(--dim); margin-top:4px; }
.insight{
  background:linear-gradient(135deg,#0a0f1a,#0c0f1c);
  border:1px solid var(--border); border-radius:12px;
  padding:12px; margin-bottom:12px;
}
.insight-title{ font-size:11px; color:var(--gold); text-transform:uppercase; margin-bottom:8px; }
.trend-item{ display:flex; justify-content:space-between; font-size:13px; margin-bottom:4px; }
.roi-impact{ margin-top:6px; font-size:11px; color:var(--green); }
.causal-link{
  font-size:10px; color:var(--dim);
  margin-top:8px; border-top:1px solid var(--border); padding-top:6px;
}
.compare{ background:var(--panel); border-radius:12px; margin-bottom:12px; overflow:auto; }
.compare table{ width:100%; font-size:11px; border-collapse:collapse; }
.compare th,.compare td{ padding:8px; border-bottom:1px solid var(--border); text-align:left; }
.compare th{ color:var(--gold); }
.vera-check{ color:var(--green); font-weight:bold; }
.risk-block{
  background:linear-gradient(135deg,#0a0f1a,#0c0f1c);
  border-left:3px solid var(--red);
  border-radius:12px; padding:12px; margin-bottom:12px;
}
.audit-box{
  background:var(--panel2); border:1px solid var(--border);
  border-radius:10px; padding:10px; margin-bottom:12px;
}
.audit-hash{ font-family:monospace; font-size:10px; opacity:0.8; word-break:break-all; }
.proof-result{
  display:none; margin-top:10px;
  background:#00000040; padding:10px;
  border-radius:8px; font-size:11px; line-height:1.8;
}
.actions{ display:flex; gap:10px; margin-bottom:12px; }
button{
  flex:1; padding:10px; border-radius:8px;
  border:1px solid var(--border); background:var(--panel2);
  color:var(--text); cursor:pointer; font-size:12px;
}
button:active{ opacity:0.7; }
.usecase{
  background:var(--panel2); border-radius:10px;
  padding:10px; font-size:11px; border-left:2px solid var(--blue);
  margin-bottom:12px;
}
.demo-badge{
  background: #fbbf24; color:#000; font-size:10px; border-radius:20px;
  padding:4px 8px; display:inline-block; margin-left:10px;
}
</style>
</head>
<body>

<div style="padding:10px;text-align:center;font-size:13px;background:#220000;border-bottom:1px solid rgba(255,0,0,0.2);">
  🚨 Without VERA: GDPR / AI Act non-compliance + unexploitable raw data
</div>

<div style="padding:10px;text-align:center;font-size:13px;background:#00000040;border-bottom:1px solid var(--border);">
  🎯 Décision en temps réel : <strong id="mainDecision">—</strong>
  <div id="decisionConfidence" style="font-size:11px;color:var(--green);margin-top:2px;"></div>
</div>

<header>
  <h1>VERA v1.4 – Deal Closer <span class="demo-badge">DÉMO STATIQUE</span></h1>
  <div class="badge">LIVE PIPELINE – PRIVACY SAFE</div>
</header>

<div class="container">

  <div class="pipeline">
    <div class="step"><div class="left"><div class="dot" style="background:var(--blue)"></div><span class="label">Data Input Stream</span></div><span class="state">audio batches</span></div>
    <div class="step"><div class="left"><div class="dot" style="background:var(--purple)"></div><span class="label">LDP Edge Layer</span></div><span class="state">ε=1.0 noise</span></div>
    <div class="step"><div class="left"><div class="dot" style="background:var(--gold)"></div><span class="label">Irreversible Signal</span></div><span class="state">aggregation</span></div>
    <div class="step"><div class="left"><div class="dot" style="background:var(--green)"></div><span class="label">Audit Layer</span></div><span class="state">RFC3161 hash chain</span></div>
  </div>

  <div class="kpis">
    <div class="kpi">
      <div class="v" id="signal">0.00</div>
      <div class="t">signal</div>
      <div class="small">Spearman</div>
    </div>
    <div class="kpi">
      <div class="v" id="integrity">0%</div>
      <div class="t">integrity</div>
    </div>
    <div class="kpi">
      <div class="v" style="color:var(--green)" id="engagementLift">0%</div>
      <div class="t">engagement lift</div>
    </div>
    <div class="kpi">
      <div class="v" id="complianceSaved" style="color:var(--gold)">€0</div>
      <div class="t">compliance saved</div>
      <div class="small">/ an</div>
    </div>
  </div>

  <div class="insight">
    <div class="insight-title">📊 INSIGHT (privacy-safe)</div>
    <div id="trendList"></div>
    <div class="roi-impact" id="roiImpact"></div>
    <div class="causal-link" id="causalLink"></div>
  </div>

  <div class="compare">
    <table>
      <tr><th></th><th>Sans VERA</th><th>Avec VERA</th></tr>
      <tr><td>Données</th><td>Brutes</th><td class="vera-check">Signal agrégé</td></tr>
      <tr><td>RGPD / AI Act</th><td>Risque élevé</th><td class="vera-check">Conforme (LDP)</td></tr>
      <tr><td>Auditabilité</th><td>Aucune</th><td class="vera-check">RFC3161 chainée</td></tr>
      <tr><td>Exploitation</th><td>Manuelle</th><td class="vera-check">Insight automatique</td></tr>
      <tr><th>Décision</th><td>Intuition</th><td class="vera-check">Data privacy-safe</td></tr>
    </table>
  </div>

  <div class="risk-block">
    <div class="insight-title">⚖️ RISK ELIMINATED</div>
    <div style="font-size:12px;line-height:1.8;">
      ❌ No raw personal data storage<br>
      ❌ No re-identification possible<br>
      ❌ No GDPR exposure surface<br><br>
      <strong style="color:var(--green)">→ Legal + compliance risk reduced by design</strong>
    </div>
  </div>

  <div class="audit-box">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
      <div>
        <div style="font-size:11px;color:var(--muted);">🔗 Anchor hash</div>
        <div class="audit-hash" id="anchorHash">sim_loading…</div>
      </div>
      <div>
        <div style="font-size:11px;color:var(--muted);">🕒 Timestamp</div>
        <div style="font-size:11px;" id="auditTimestamp">—</div>
      </div>
      <div>
        <div style="font-size:11px;color:var(--muted);">✅ Status</div>
        <div style="font-size:11px;" id="auditStatus">—</div>
      </div>
    </div>
    <div class="proof-result" id="proofResult"></div>
  </div>

  <div class="actions">
    <button id="verifyBtn">🔐 Verify & Download Proof (démo)</button>
    <button onclick="window.location.reload()">⟳ Rafraîchir (données aléatoires)</button>
  </div>

  <div class="usecase">
    <strong>🎯 Use case : Radio FMR</strong><br>
    Dataset anonymisé (agrégation irréversible) – 150k auditeurs → tendance Rap FR détectée en soirée.<br>
    Résultat : +12% d'écoute sur 22h–23h. Coût AI Act évité : ~45k€/an.<br>
    <span style="color:var(--gold);font-size:10px;">🔹 Version démo – données simulées mais réalistes</span>
  </div>

</div>

<script>
let currentSignal = 0.91;
let batchCount = 156;
let intervalId;

function computeInsight(signal) {
  if (signal > 0.92) {
    return {
      genre: "Rap FR +" + Math.floor(10 + (signal-0.92)*50) + "%",
      peak: "22h–23h (+" + Math.floor(30 + (signal-0.9)*40) + "%)",
      skip: "-" + Math.floor(8 + (signal-0.9)*20) + "% contenus courts",
      action: "Augmenter playlist Rap FR en soirée",
      impact: "+" + Math.floor(5 + (signal-0.92)*15) + "% engagement ≈ +" + Math.floor(10 + (signal-0.92)*40) + "k€/mois",
      lift: "+" + Math.floor(12 + (signal-0.92)*20) + "%"
    };
  } else if (signal > 0.87) {
    return {
      genre: "Podcast true crime +" + Math.floor(15 + (signal-0.87)*30) + "%",
      peak: "20h–21h (+" + Math.floor(20 + (signal-0.85)*20) + "%)",
      skip: "-" + Math.floor(6 + (signal-0.85)*10) + "% longs formats",
      action: "Épisodes 45 min en prime time",
      impact: "+" + Math.floor(3 + (signal-0.87)*10) + "% fidélisation ≈ +" + Math.floor(6 + (signal-0.87)*20) + "k€/mois",
      lift: "+" + Math.floor(8 + (signal-0.87)*15) + "%"
    };
  } else {
    return {
      genre: "Pop urbaine +" + Math.floor(5 + (signal-0.82)*20) + "%",
      peak: "18h–19h (+" + Math.floor(10 + (signal-0.8)*15) + "%)",
      skip: "-" + Math.floor(3 + (signal-0.8)*8) + "% nouveautés",
      action: "Mettre en avant sorties récentes 18h",
      impact: "+" + Math.floor(1 + (signal-0.82)*8) + "% rétention ≈ +" + Math.floor(2 + (signal-0.82)*10) + "k€/mois",
      lift: "+" + Math.floor(5 + (signal-0.82)*10) + "%"
    };
  }
}

function update() {
  const i = computeInsight(currentSignal);
  document.getElementById('trendList').innerHTML = `
    <div class="trend-item"><span>🎧 Top genre :</span><span>${i.genre}</span></div>
    <div class="trend-item"><span>⏱️ Pic d'écoute :</span><span>${i.peak}</span></div>
    <div class="trend-item"><span>📉 Skip rate :</span><span>${i.skip}</span></div>
  `;
  document.getElementById('roiImpact').innerText = "📈 " + i.impact;
  document.getElementById('mainDecision').innerText = i.action;
  document.getElementById('decisionConfidence').innerHTML = `Confiance: ${(currentSignal * 100).toFixed(1)}% (simulation)`;
  document.getElementById('signal').innerText = currentSignal.toFixed(3);
  document.getElementById('causalLink').innerHTML = `🔗 Causal chain: signal=${currentSignal.toFixed(3)} → aggregated (ε=1.0 LDP) → batch=${batchCount} → decision: ${i.action}`;
  document.getElementById('engagementLift').innerText = i.lift;
  let saved = 45000 + Math.floor((currentSignal - 0.85) * 20000);
  document.getElementById('complianceSaved').innerText = '€' + saved.toLocaleString();
  let integrity = Math.min(99.9, Math.max(97.0, 98.5 + (currentSignal - 0.85) * 15));
  document.getElementById('integrity').innerText = integrity.toFixed(1) + '%';
  document.getElementById('anchorHash').innerHTML = 'sha256_' + Math.abs(Math.sin(currentSignal * 1000)).toString(36).substring(2, 18) + '…';
  document.getElementById('auditTimestamp').innerText = new Date().toLocaleString();
  document.getElementById('auditStatus').innerHTML = '✅ VERIFIED (démo)';
}

function randomWalk() {
  currentSignal += (Math.random() - 0.5) * 0.008;
  currentSignal = Math.min(0.98, Math.max(0.82, currentSignal));
  batchCount += Math.floor(Math.random() * 5) + 1;
  update();
}

function demoVerify() {
  const btn = document.getElementById('verifyBtn');
  const box = document.getElementById('proofResult');
  btn.innerText = '⏳ Génération preuve...';
  box.style.display = 'block';
  const proof = {
    status: "VALID (demo)",
    authority: "RFC3161 Qualified TSA (simulé)",
    anchor_hash: `sha256_demo_${Math.random().toString(36).substring(2, 10)}`,
    timestamp: new Date().toISOString(),
    signal: currentSignal,
    epsilon: 1.0,
    k_min: 100,
    compliance: ["RGPD", "AI Act", "RFC3161"],
    disclaimer: "Données simulées à titre de démonstration"
  };
  box.innerHTML = `
    <div style="font-size:12px;line-height:1.8;">
      🔐 <strong>RFC3161 Timestamp Proof (demo)</strong><br><br>
      ✅ Status: <strong style="color:#34d399">${proof.status}</strong><br>
      🏛 Authority: ${proof.authority}<br>
      🧬 Anchor hash:<br><span class="audit-hash">${proof.anchor_hash}</span><br><br>
      ⏱ Timestamp: ${proof.timestamp}<br>
      📊 Signal (Spearman): ${proof.signal}<br>
      🛡️ Epsilon: ${proof.epsilon}<br>
      <div style="padding:6px;background:#00000040;border-radius:6px;margin-top:8px;">
        ⚠️ Version démo – preuve générée localement.
      </div>
    </div>
  `;
  const blob = new Blob([JSON.stringify(proof, null, 2)], { type: "application/json" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `vera_proof_demo_${Date.now()}.json`;
  a.click();
  URL.revokeObjectURL(url);
  btn.innerText = '🔐 Verify & Download Proof (démo)';
}

function startSimulation() {
  if (intervalId) clearInterval(intervalId);
  update();
  intervalId = setInterval(randomWalk, 3500);
}

document.getElementById('verifyBtn').onclick = demoVerify;
const refreshBtn = document.querySelector('.actions button:last-child');
if (refreshBtn && refreshBtn.innerText.includes('Rafraîchir')) {
  refreshBtn.onclick = () => { randomWalk(); return false; };
}
startSimulation();
</script>
</body>
</html>